# Copy to .env before running docker compose, or export these variables in shell.
FRONTEND_PORT=8080

JWT_SECRET=please-change-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=please-change-admin-password
CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080

MAX_UPLOAD_SIZE_MB=50
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
DOCX_VISION_MAX_IMAGES=20
