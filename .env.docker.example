# Copy to .env before running docker compose, or export these variables in shell.
FRONTEND_PORT=8080

JWT_SECRET=please-change-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=please-change-admin-password
CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080

MAX_UPLOAD_SIZE_MB=50
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
DOCX_VISION_MAX_IMAGES=20
AGENT_RUNTIME=local-openclaw
# 使用 OpenClaw Gateway 知识库智能体时，改为：
# AGENT_RUNTIME=openclaw
# OPENCLAW_ENDPOINT=http://host.docker.internal:<openclaw-port>
OPENCLAW_ENDPOINT=
OPENCLAW_API_KEY=
OPENCLAW_AGENT=main
OPENCLAW_WEB_SKILLS=browser-automation
