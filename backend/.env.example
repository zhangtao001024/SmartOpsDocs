JWT_SECRET=change-me
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=admin123
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
KNOWLEDGE_DIR=./data/knowledge
MAX_UPLOAD_SIZE_MB=50
OPENAI_API_KEY=
OPENAI_BASE_URL=
